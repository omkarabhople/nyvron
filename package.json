{
  "name": "nyvron",
  "version": "1.0.0",
  "description": "NYVRON — Personal command center. iOS-inspired productivity dashboard.",
  "main": "main.js",
  "author": "Antigravity",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "express": "^4.19.0",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "electron": "^30.0.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nyvron.app",
    "productName": "NYVRON",
    "files": [
      "main.js",
      "frontend/**/*",
      "backend/**/*"
    ],
    "extraResources": [
      "insert api key here"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "background": null,
      "iconSize": 100,
      "contents": [
        {
          "x": 130,
          "y": 150,
          "type": "file"
        },
        {
          "x": 410,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
